{
  "cases": [
    {
      "name": "top_nav_enter_does_not_fallthrough_to_body",
      "screen": "main_menu_screen",
      "context": {},
      "keys": ["UP", "ENTER"],
      "expect_events": ["topnav_power"]
    },
    {
      "name": "button_list_top_nav_back_on_enter",
      "screen": "button_list_screen",
      "context": {
        "top_nav": {
          "title": "Menu",
          "show_back_button": true,
          "show_power_button": false
        },
        "button_list": ["Alpha", "Beta", "Gamma"]
      },
      "keys": ["UP", "ENTER"],
      "expect_events": ["topnav_back"]
    },
    {
      "name": "main_menu_top_nav_enter_after_body_move",
      "screen": "main_menu_screen",
      "context": {},
      "keys": ["RIGHT", "UP", "ENTER"],
      "expect_events": ["topnav_power"]
    },
    {
      "name": "grid_restore_last_body_selection_after_top_nav",
      "screen": "main_menu_screen",
      "context": {},
      "keys": ["RIGHT", "UP", "DOWN", "ENTER"],
      "expect_events": ["Seeds"]
    }
  ]
}
